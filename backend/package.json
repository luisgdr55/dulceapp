{
  "name": "dulceapp-backend",
  "version": "1.0.0",
  "description": "DULCEAPP Backend API — Node.js + Express + Prisma",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "db:use-dev": "cp prisma/schema.dev.prisma prisma/schema.prisma && npx prisma generate",
    "db:use-prod": "cp prisma/schema.prod.prisma prisma/schema.prisma && npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "grammy": "^1.31.0",
    "jose": "^5.9.6",
    "node-cron": "^3.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
