# ── Base de datos ───────────────────────────────────────────────────────────────
# Desarrollo local (SQLite):
# DATABASE_URL="file:./dev.db"
#
# Producción Railway — referenciar el addon:
DATABASE_URL="${{PostgreSQL.DATABASE_URL}}"

# ── Auth ────────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET="CAMBIA_ESTO_POR_UN_STRING_LARGO_Y_ALEATORIO"
JWT_EXPIRES_IN="7d"

# ── IA — OpenRouter ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="google/gemini-2.0-flash-001"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# ── Telegram ────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
TELEGRAM_ENCRYPTION_KEY="CAMBIA_ESTO_POR_64_CHARS_HEX"

# ── Servidor ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# URL pública del frontend en Railway (agregar después de desplegar el frontend)
FRONTEND_URL="https://dulceapp-frontend.up.railway.app"

# ── Cron BCV ────────────────────────────────────────────────────────────────────
BCV_CRON_ENABLED=true
BCV_CRON_SCHEDULE="0 8 * * 1-5"

# ── Rate limiting ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
