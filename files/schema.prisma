// DULCEAPP — Schema Prisma multi-tenant
// Cada tabla con datos de negocio incluye workspaceId
// Migración directa desde SQLite → PostgreSQL (Railway addon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// CAPA 0: PLATAFORMA GLOBAL
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nombre       String
  apellido     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships      WorkspaceMember[]
  aiConversations  AIConversation[]
  auditLogs        AuditLog[]
}

model Workspace {
  id        String   @id @default(cuid())
  slug      String   @unique           // URL amigable: "dulce-patisserie"
  nombre    String
  plan      Plan     @default(FREE)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members          WorkspaceMember[]
  businessConfig   BusinessConfig?
  tasasBCV         TasaBCV[]
  backupConfig     BackupConfig?
  ingredientes     Ingrediente[]
  recetas          Receta[]
  pedidos          Pedido[]
  notificaciones   Notificacion[]
  auditLogs        AuditLog[]
  aiConversations  AIConversation[]
  telegramSession  TelegramSession?
}

model WorkspaceMember {
  id          String          @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole   @default(EDITOR)
  createdAt   DateTime        @default(now())

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

enum Plan {
  FREE        // 1 usuario, 50 recetas, 100 pedidos/mes
  PRO         // 3 usuarios, ilimitado
  BUSINESS    // N usuarios, analytics avanzados, API Telegram
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

// ─────────────────────────────────────────────
// CAPA 1: CONFIGURACIÓN DEL NEGOCIO
// ─────────────────────────────────────────────

model BusinessConfig {
  id                String    @id @default(cuid())
  workspaceId       String    @unique
  nombre            String
  apellido          String?
  negocio           String
  ciudad            String?
  email             String?
  telefono          String?
  monedaPrincipal   String    @default("EUR")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model TasaBCV {
  id          String    @id @default(cuid())
  workspaceId String
  tasa        Float
  fecha       DateTime  @default(now())
  esCurrent   Boolean   @default(false)
  fuente      String    @default("manual")  // "manual" | "auto-cron"
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, esCurrent])
}

model BackupConfig {
  id                   String    @id @default(cuid())
  workspaceId          String    @unique
  autoBackup           Boolean   @default(false)
  frecuencia           String    @default("semanal")
  horaBackup           String    @default("02:00")
  diaSemana            Int       @default(1)
  ultimoBackup         DateTime?
  ultimoBackupArchivo  String?
  updatedAt            DateTime  @updatedAt

  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// CAPA 2: INVENTARIO Y RECETARIO
// ─────────────────────────────────────────────

model Ingrediente {
  id              String    @id @default(cuid())
  workspaceId     String
  nombre          String
  categoria       String?
  unidad          String
  cantidadActual  Float     @default(0)
  cantidadMinima  Float     @default(0)
  precioEur       Float     @default(0)
  proveedor       String?
  notas           String?
  esAccesorio     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recetaItems     RecetaIngrediente[]

  @@index([workspaceId])
  @@index([workspaceId, cantidadActual]) // para queries de stock bajo
}

model Receta {
  id                  String    @id @default(cuid())
  workspaceId         String
  nombre              String
  descripcion         String?
  categoria           String?
  imagenUrl           String?
  porciones           Int       @default(1)
  tiempoPrep          Int?      // minutos
  costoIngredientesEur Float    @default(0)
  costoGasEur         Float     @default(0)
  costoEmpaqueEur     Float     @default(0)
  costoTotalEur       Float     @default(0)
  precioVentaEur      Float     @default(0)
  margenGanancia      Float     @default(0)
  notas               String?
  activa              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ingredientes        RecetaIngrediente[]
  variantes           RecetaVariante[]
  pedidos             Pedido[]

  @@index([workspaceId])
}

model RecetaIngrediente {
  id            String      @id @default(cuid())
  recetaId      String
  ingredienteId String
  cantidad      Float
  unidad        String

  receta        Receta      @relation(fields: [recetaId], references: [id], onDelete: Cascade)
  ingrediente   Ingrediente @relation(fields: [ingredienteId], references: [id], onDelete: Cascade)

  @@unique([recetaId, ingredienteId])
}

model RecetaVariante {
  id          String    @id @default(cuid())
  recetaId    String
  nombre      String
  precioEur   Float
  descripcion String?

  receta      Receta    @relation(fields: [recetaId], references: [id], onDelete: Cascade)
  pedidos     Pedido[]
}

// ─────────────────────────────────────────────
// CAPA 3: PEDIDOS, NOTIFICACIONES Y AUDITORÍA
// ─────────────────────────────────────────────

model Pedido {
  id              String        @id @default(cuid())
  workspaceId     String
  numeroPedido    String
  recetaId        String?
  varianteId      String?
  cantidad        Int           @default(1)
  precioUnitarioEur Float       @default(0)
  totalEur        Float         @default(0)
  totalBs         Float         @default(0)
  costoTotalEur   Float         @default(0)
  gananciaEur     Float         @default(0)
  clienteNombre   String?
  clienteTelefono String?
  clienteDireccion String?
  fechaEntrega    DateTime?
  estado          PedidoEstado  @default(PENDIENTE)
  tasaBcvUsada    Float         @default(0)
  notas           String?
  ventaRapida     Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  receta          Receta?         @relation(fields: [recetaId], references: [id])
  variante        RecetaVariante? @relation(fields: [varianteId], references: [id])
  tags            PedidoTag[]

  @@unique([workspaceId, numeroPedido])
  @@index([workspaceId, estado])
  @@index([workspaceId, fechaEntrega])
  @@index([workspaceId, createdAt])
}

model PedidoTag {
  id       String @id @default(cuid())
  pedidoId String
  tag      String

  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
}

enum PedidoEstado {
  PENDIENTE
  EN_PROCESO
  ENTREGADO
  CANCELADO
}

model Notificacion {
  id          String    @id @default(cuid())
  workspaceId String
  tipo        String
  titulo      String
  mensaje     String
  leida       Boolean   @default(false)
  referenciaId String?
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, leida])
}

// Auditoría: quién hizo qué y cuándo (clave para multi-tenant)
model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String?
  canal       String    @default("web")   // "web" | "telegram" | "cron"
  accion      String                      // "crear_pedido" | "actualizar_stock" | etc.
  entidad     String                      // "Pedido" | "Ingrediente" | etc.
  entidadId   String?
  payload     Json?                       // snapshot antes/después
  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id])

  @@index([workspaceId, createdAt])
  @@index([workspaceId, entidad])
}

// ─────────────────────────────────────────────
// CAPA 4: IA Y TELEGRAM
// ─────────────────────────────────────────────

model AIConversation {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String?
  canal       String    @default("web")   // "web" | "telegram"
  messages    Json                        // array de {role, content}
  activa      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id])
  actions     AIAction[]
}

// Registro de cada tool call ejecutada por el LLM
model AIAction {
  id             String         @id @default(cuid())
  conversationId String
  tool           String         // "crear_pedido" | "actualizar_stock" | etc.
  params         Json
  resultado      Json?
  confirmada     Boolean        @default(false)
  ejecutada      Boolean        @default(false)
  createdAt      DateTime       @default(now())

  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// Una sesión de Telegram por workspace (bot propio o compartido)
model TelegramSession {
  id            String    @id @default(cuid())
  workspaceId   String    @unique
  chatId        String                      // Telegram chat ID de la repostera
  botToken      String                      // token del bot de Telegram (cifrado)
  activa        Boolean   @default(true)
  lastActivity  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
